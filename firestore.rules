rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ── loan_applications ─────────────────────────────────────────
    // Authenticated users can create their own applications.
    // Users can only read/update their own; admins can read all.
    // Only admins can delete.
    match /loan_applications/{docId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow read, update: if isSignedIn()
                          && (isOwner(resource.data.userId)
                              || request.auth.token.admin == true);

      allow delete: if isSignedIn()
                    && request.auth.token.admin == true;
    }

    // ── applications ──────────────────────────────────────────────
    match /applications/{docId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow read, update: if isSignedIn()
                          && (isOwner(resource.data.userId)
                              || request.auth.token.admin == true);

      allow delete: if isSignedIn()
                    && request.auth.token.admin == true;
    }

    // ── users ─────────────────────────────────────────────────────
    // Users can only read and write their own profile document.
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
